# apps/api — source of truth for env vars. Every var is validated by Zod at boot.
# Copy to .env and fill in. .env is git-ignored.

NODE_ENV=development
PORT=4000

# MongoDB connection string. Use mongodb+srv:// (TLS) in production.
MONGO_URI=mongodb://localhost:27017/pulsehq

# Comma-separated. First signs; all are accepted on verify (rotation).
# Generate: openssl rand -base64 48
JWT_ACCESS_SECRET=dev-only-change-me-please-0000000000000000000000
JWT_ACCESS_TTL_SECONDS=900

# HMAC pepper for hashing refresh/reset tokens at rest. >= 32 bytes.
# Generate: openssl rand -base64 48
REFRESH_TOKEN_PEPPER=dev-only-change-me-please-0000000000000000000000
REFRESH_TOKEN_TTL_DAYS=30

# Comma-separated allowlist. No wildcards in prod. No http:// in prod.
CORS_ORIGINS=http://localhost:3000

# Cookies
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Mail (optional in dev)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=PulseHQ <no-reply@pulsehq.dev>

LOG_LEVEL=info
