{
  "name": "dashboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build && (vite build --watch & vite preview --port 3001 --strictPort)",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 3001 --strictPort",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist .turbo node_modules/.vite"
  },
  "dependencies": {
    "@pulse/api-client": "workspace:*",
    "@pulse/auth": "workspace:*",
    "@pulse/types": "workspace:*",
    "@pulse/ui": "workspace:*",
    "@tanstack/react-query": "^5.59.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@originjs/vite-plugin-federation": "^1.3.9",
    "@pulse/eslint-config": "workspace:*",
    "@pulse/tailwind-config": "workspace:*",
    "@pulse/tsconfig": "workspace:*",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.13.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}